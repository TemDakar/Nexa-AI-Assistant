[Unit]
Description=Nexa Access API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/nexa-max-access
EnvironmentFile=/opt/nexa-max-access/nexa-max-access.env
ExecStart=/opt/nexa-max-access/venv/bin/uvicorn nexa_max_access:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
