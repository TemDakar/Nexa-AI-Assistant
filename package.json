{
	"name": "nexa-assistant",
	"version": "0.0.1",
	"description": "Nexa voice assistant",
	"author": "Nexa",
	"repository": {
		"type": "git",
		"url": "https://github.com/whydarcy/nexa_assistant.git"
	},
	"main": "dist/main.js",
	"scripts": {
		"build": "node scripts/build-renderer.js",
		"setup:voice": "node scripts/setup-voice.js",
		"setup:voice:mac": "bash scripts/setup-voice-macos.sh",
		"start": "electron .",
		"start:mac": "env -u ELECTRON_RUN_AS_NODE electron .",
		"dist:win": "npm run build && electron-builder --win",
		"dist:mac": "npm run build && electron-builder --mac",
		"dist:linux": "npm run build && electron-builder --linux",
		"dist": "npm run build && electron-builder --win --mac --linux",
		"dist:publish": "npm run build && electron-builder --win --mac --linux --publish always",
		"dist:publish:win": "npm run build && electron-builder --win --publish always"
	},
	"build": {
		"appId": "com.nexa.app",
		"productName": "Nexa",
		"directories": {
			"output": "release",
			"buildResources": "build"
		},
		"files": [
			"dist/**/*",
			"renderer/**/*",
			"package.json"
		],
		"extraResources": [
			{
				"from": "resources",
				"to": "resources",
				"filter": [
					"**/*",
					"!**/.venv/**",
					"!**/__pycache__/**"
				]
			}
		],
		"publish": [
			{
				"provider": "github",
				"owner": "whydarcy",
				"repo": "nexa_assistant",
				"releaseType": "release"
			}
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": ["x64"]
				}
			],
			"icon": "build/icon.ico",
			"artifactName": "${productName}-Setup-${version}.${ext}"
		},
		"mac": {
			"target": ["dmg", "zip"],
			"category": "public.app-category.productivity",
			"icon": "build/icon.ico",
			"artifactName": "${productName}-${version}-${arch}.${ext}"
		},
		"linux": {
			"target": ["AppImage", "deb"],
			"category": "Utility",
			"icon": "build/icon.ico",
			"artifactName": "${productName}-${version}-${arch}.${ext}",
			"maintainer": "Nexa <nexa@local>"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"allowElevation": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "Nexa",
			"installerIcon": "build/icon.ico",
			"uninstallerIcon": "build/icon.ico",
			"license": "LICENSE.txt",
			"runAfterFinish": true
		},
		"compression": "maximum",
		"asar": true,
		"asarUnpack": [
			"resources/whisper/whisper_recognition.exe",
			"resources/ffmpeg/ffmpeg.exe"
		],
		"npmRebuild": false
	},
	"dependencies": {
		"electron-updater": "^6.6.2",
		"smart-buffer": "^4.2.0",
		"telegram": "^2.26.22"
	},
	"devDependencies": {
		"electron": "^28.3.3",
		"electron-builder": "^24.9.1"
	}
}
